{
  auto_https off
  admin off
}

(auth) {
    # Intercept sign_out before oauth2-proxy sees it: send the browser to
    # Keycloak's end_session endpoint first (clears the Keycloak browser
    # session), then Keycloak redirects to sso/oauth2/sign_out which clears
    # the proxy cookie.  Without this, oauth2-proxy only clears the local
    # cookie and Keycloak's SSO session survives → silent re-auth on next visit.
    handle /oauth2/sign_out {
        redir * http://keycloak.celine.localhost/realms/celine/protocol/openid-connect/logout?client_id=oauth2_proxy&post_logout_redirect_uri=http%3A%2F%2Fsso.celine.localhost%2Foauth2%2Fsign_out 302
    }

    # Exclude /oauth2/* so other oauth2 paths (sign_in, callback) bypass this
    # check and route directly to oauth2-proxy without an auth pre-flight.
    @needs_auth not path /oauth2/*
    forward_auth @needs_auth host-gw:4180 {
        uri /oauth2/auth

        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Host {host}

        copy_headers \
            X-Auth-Request-User \
            X-Auth-Request-Email \
            X-Auth-Request-Groups \
            X-Auth-Request-Access-Token \
            Authorization

        @unauthenticated status 401
        handle_response @unauthenticated {
            redir * http://sso.celine.localhost/oauth2/sign_in?rd={scheme}://{hostport}{uri}
        }
    }
}

http://superset.celine.localhost {
    import auth
    reverse_proxy host-gw:8088
}

http://jupyter.celine.localhost {
    import auth
    reverse_proxy host-gw:8888
}

http://keycloak.celine.localhost {
  reverse_proxy host-gw:8080
}

http://sso.celine.localhost {
  handle /oauth2/* {
    reverse_proxy host-gw:4180
  }
  # bare redir must be inside handle to stay exclusive with the block above;
  # otherwise Caddy runs it for /oauth2/* too, forwarding callback codes to webapp.
  handle {
    redir * http://webapp.celine.localhost{uri} 302
  }
}

http://mqtt.celine.localhost {
  reverse_proxy host-gw:1884
}

# Pipelines
http://marquez.celine.localhost {
  import auth
  reverse_proxy host-gw:5002
}

http://prefect.celine.localhost {
  import auth
  reverse_proxy host-gw:4200
}

# UIs
http://assistant.celine.localhost {
  
  # handle sign_out
  handle /oauth2/* {
    reverse_proxy host-gw:4180
  }

  import auth

  handle_path /api/* {
    reverse_proxy host-gw:8012
  }

  reverse_proxy host-gw:3003
}

http://webapp.celine.localhost {
  route {
    # handle sign_out
    handle /oauth2/* {
      reverse_proxy host-gw:4180
    }

    # service worker must stay fetchable without auth redirects
    handle /sw.js {
      reverse_proxy host-gw:3005
    }

    import auth

    handle_path /api/assistant/* {
      reverse_proxy host-gw:8012
    }

    handle /api* {
      reverse_proxy host-gw:8014
    }

    handle {
      reverse_proxy host-gw:3005
    }
  }
}


# APIs
http://api.celine.localhost {
 
  handle_path /datasets* {
    reverse_proxy host-gw:8001
  }

  handle_path /dt* {
    reverse_proxy host-gw:8002
  }

  handle_path /rec-registry* {
    reverse_proxy host-gw:8004
  }

  handle_path /mqtt* {
    reverse_proxy host-gw:8009
  }

  handle_path /webapp* {
    reverse_proxy host-gw:8014
  }

  handle_path /assistant* {
    reverse_proxy host-gw:8012
  }

  handle_path /nudging* {
    reverse_proxy host-gw:8016
  }
}
